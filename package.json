{
  "name": "setup-kubeconform",
  "version": "1.0.0",
  "private": true,
  "description": "Sets up the Kubeconform CLI in your GitHub Actions workflow.",
  "main": "dist/index.js",
  "scripts": {
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "lint": "eslint src/ test/",
    "compile": "esbuild src/main.ts --bundle --platform=node --target=node24 --format=cjs --outfile=dist/index.js",
    "build": "npm run check && npm run compile",
    "check": "npm run format && npm run lint",
    "test": "jest"
  },
  "engines": {
    "node": "24.x"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bmuschko/setup-kubeconform.git"
  },
  "author": "Benjamin Muschko",
  "keywords": [
    "github",
    "actions",
    "github-actions",
    "kubeconform"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bmuschko/setup-kubeconform/issues"
  },
  "homepage": "https://github.com/bmuschko/setup-kubeconform/README.md",
  "dependencies": {
    "@actions/core": "3.0.1",
    "@actions/tool-cache": "4.0.0"
  },
  "devDependencies": {
    "@jest/globals": "30.4.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/jest": "30.0.0",
    "@types/node": "26.1.1",
    "esbuild": "0.28.1",
    "eslint": "10.7.0",
    "eslint-plugin-github": "6.1.0",
    "eslint-plugin-jest": "29.15.4",
    "jest": "30.4.2",
    "prettier": "3.9.6",
    "ts-jest": "29.4.11",
    "typescript": "5.9.3"
  },
  "overrides": {
    "glob": "13.0.6"
  }
}
